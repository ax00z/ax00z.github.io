---
import BaseLayout from './BaseLayout.astro';

interface Props { 
  frontmatter: { title: string; description: string; date: string; tags?: string[]; };
}

const { frontmatter } = Astro.props;
const d = new Date(frontmatter.date).toLocaleDateString('en-US', { timeZone: 'UTC', year: 'numeric', month: 'short', day: 'numeric' });
---
<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article>
    <header class="post-head">
      <div class="post-meta"><time datetime={frontmatter.date}>{d}</time></div>
      <h1>{frontmatter.title}</h1>
      {frontmatter.description && <p class="post-desc">{frontmatter.description}</p>}
      {frontmatter.tags && <div class="tags">{frontmatter.tags.map(t => <span class="tag">{t}</span>)}</div>}
    </header>
    <div class="prose"><slot /></div>
    <a href="/blog/" class="back-link">← All posts</a>
  </article>
</BaseLayout>