---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found">
  <section class="hero" style="text-align: center;">
    <h1>404</h1>
    <p class="hero-bio" style="margin: 0 auto;">
      This page doesn't exist. Maybe it did once, maybe it never will.
    </p>
    <p style="margin-top: 1.5rem;">
      <a href="/" style="font-family: var(--font-mono); font-size: 0.85rem;">← Back home</a>
    </p>
  </section>
</BaseLayout>
