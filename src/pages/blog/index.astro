---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).filter(p => !p.data.draft).sort((a,b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const fmt = (d) => new Date(d).toLocaleDateString('en-US', { timeZone: 'UTC', year: 'numeric', month: 'short', day: 'numeric' });
---
<BaseLayout title="Blog">
  <header class="pg-head">
    <h1>Blog</h1>
    <p class="sub">Building in public. Notes on data, systems, and whatever I'm working through.</p>
  </header>
  <div class="posts gap-bot">
    {posts.map(p => (
      <a href={`/blog/${p.slug}/`} class="post-row">
        <div>
          <span class="post-row-title">{p.data.title}</span>
          {p.data.tags && <div class="tags">{p.data.tags.map(t => <span class="tag">{t}</span>)}</div>}
        </div>
        <span class="post-row-date">{fmt(p.data.date)}</span>
      </a>
    ))}
  </div>
</BaseLayout>