---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const formatDate = (dateStr: string) =>
  new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="Blog" description="Writing about software engineering, CS fundamentals, projects, and the job search.">
  <header class="page-header">
    <h1>Blog</h1>
    <p class="subtitle">
      Notes on what I'm learning, building, and figuring out. Mostly software engineering,
      some career stuff.
    </p>
  </header>

  <div class="post-list mb-section">
    {posts.map(post => (
      <a href={`/blog/${post.slug}/`} class="post-item">
        <div>
          <span class="post-title">{post.data.title}</span>
          {post.data.tags && (
            <div class="tag-list">
              {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
        <span class="post-date">{formatDate(post.data.date)}</span>
      </a>
    ))}
  </div>
</BaseLayout>
